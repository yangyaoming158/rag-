# DevDocs RAG local environment.
# Copy to .env for Docker Compose. Never commit .env.

POSTGRES_DB=devdocs_rag
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_PORT=5433

BACKEND_PORT=8080
FRONTEND_PORT=3000

RAG_JWT_SECRET=replace-with-at-least-32-random-characters
RAG_JWT_EXPIRATION_MINUTES=480
RAG_STORAGE_ROOT=/app/data/files

# Mock providers are the default and must keep the app runnable without keys.
RAG_AI_CHAT_PROVIDER=mock
RAG_AI_CHAT_BASE_URL=
RAG_AI_CHAT_API_KEY=
RAG_AI_CHAT_MODEL=mock-chat
RAG_AI_CHAT_TEMPERATURE=0.2

RAG_AI_EMBEDDING_PROVIDER=mock
RAG_AI_EMBEDDING_BASE_URL=
RAG_AI_EMBEDDING_API_KEY=
RAG_AI_EMBEDDING_MODEL=mock-bge-m3
RAG_AI_EMBEDDING_DIMENSIONS=1024
RAG_AI_EMBEDDING_MAX_BATCH_SIZE=32

# Retrieval defaults are tuned for the checked-in Mock provider baseline.
# Recalibrate before changing these values for a real embedding provider.
RAG_RETRIEVAL_MIN_SIMILARITY=0.35
RAG_RETRIEVAL_DEFAULT_TOP_K=8
RAG_RETRIEVAL_MAX_TOP_K=20
